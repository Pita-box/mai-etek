# ── Application ────────────────────────────
NODE_ENV=development
SITE_URL=http://localhost:3000
API_URL=http://localhost:4000

# ── Supabase / PostgreSQL ──────────────────
POSTGRES_PASSWORD=postgres
DATABASE_URL=postgres://postgres:postgres@localhost:5432/domsub
SUPABASE_URL=http://localhost:54321
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_KEY=

# ── JWT ────────────────────────────────────
JWT_SECRET=super_secret_jwt_key_for_development
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# ── Redis ──────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── MinIO ──────────────────────────────────
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=domsub-media

# ── Telegram ───────────────────────────────
TELEGRAM_BOT_TOKEN=

# ── Chrome Extension ──────────────────────
EXTENSION_SYNC_INTERVAL=30000
EXTENSION_SCREENSHOT_QUALITY=0.7
EXTENSION_MAX_BUFFER_SIZE=1000
